{
  "name": "@vcueto/agent-viz",
  "version": "0.1.0",
  "description": "Real-time visualizer for Claude Code sessions: live event stream, token tracking, multi-agent topology.",
  "bin": {
    "agent-viz": "bin/agent-viz.js"
  },
  "main": "lib/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "lib/",
    "public/",
    "index.html",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/agent-viz.js start --foreground",
    "stop": "node bin/agent-viz.js stop",
    "status": "node bin/agent-viz.js status",
    "preuninstall": "node lib/preuninstall.js",
    "prepublishOnly": "npm pack --dry-run"
  },
  "keywords": [
    "claude-code",
    "claude",
    "visualizer",
    "hooks",
    "agent",
    "observability",
    "dashboard",
    "sse",
    "tracing"
  ],
  "author": "pitchan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pitchan/agent-viz.git"
  },
  "bugs": {
    "url": "https://github.com/pitchan/agent-viz/issues"
  },
  "homepage": "https://github.com/pitchan/agent-viz#readme",
  "publishConfig": {
    "access": "public"
  }
}
